# The product's ONE configuration surface (both modules + web; 12-factor, validated at startup
# with errors naming the offending setting). See packages/web/src/lib/server/config.ts.
# Webhook-era settings (peer URLs, signing secrets) no longer exist and are ignored if present.

# --- web ---------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- downloader module -------------------------------------------------------
LIBRARY_ROOT=/music/library
STAGING_ROOT=/music/staging
DOWNLOADER_DATABASE_FILE=data/downloader/events.db
SLSKD_BASE_URL=http://localhost:5030
SLSKD_API_KEY=change-me
#MUSICBRAINZ_BASE_URL=
#MUSICBRAINZ_USER_AGENT=

# --- importer module ---------------------------------------------------------
INTAKE_ROOT=/music/intake
BEETS_CONFIG=/config/beets/config.yaml
IMPORTER_DATABASE_FILE=data/importer/events.db
#BRIDGE_PYTHON=python3
# Bundled deployments must point at the shipped bridge.py (the packaged default resolves
# beside the importer module, which bundling relocates):
#BRIDGE_SCRIPT=
#BRIDGE_TIMEOUT_MS=600000
#AUTO_APPLY_THRESHOLD=0.04
# The namespace delivered locations fall under; defaults to LIBRARY_ROOT (deliveries are
# deposits under the downloader's library root), re-rooted onto INTAKE_ROOT at intake:
#INTAKE_SOURCE_ROOT=
