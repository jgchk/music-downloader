# Music-downloader configuration (12-factor: all config comes from the environment).
# Copy to .env for local use. Required vars fail startup fast if missing.

# --- Required ---------------------------------------------------------------------------------
# Where validated releases are organized into the library, and where in-flight downloads stage.
LIBRARY_ROOT=/music/library
STAGING_ROOT=/music/staging

# --- HTTP server (optional; defaults shown) ---------------------------------------------------
HTTP_PORT=3000
HTTP_HOST=0.0.0.0

# --- Event store (optional) -------------------------------------------------------------------
DATABASE_FILE=data/events.db

# --- Logging (optional) -----------------------------------------------------------------------
LOG_LEVEL=info

# --- MusicBrainz metadata source (optional; sensible defaults are built in) --------------------
# MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
# MUSICBRAINZ_USER_AGENT=music-downloader/0.0 (https://github.com/you/music-downloader)

# --- slskd (Soulseek) source (optional endpoint; API key is a secret — never commit it) -------
# SLSKD_BASE_URL=http://localhost:5030
# SLSKD_API_KEY=

# --- MCP OAuth 2.1 Resource Server (optional; config-dormant) ---------------------------------
# When OAUTH_ISSUER is set, POST /mcp requires a valid bearer access token (JWT) minted by the
# issuer and audience-bound to OAUTH_RESOURCE, and GET /.well-known/oauth-protected-resource is
# published (RFC 9728). Unset ⇒ /mcp stays unauthenticated and no well-known route exists.
# OAUTH_RESOURCE is REQUIRED whenever OAUTH_ISSUER is set (audience validation is mandatory).
# OAUTH_JWKS_URI is optional; absent, the JWKS URI is discovered from the issuer's OIDC document.
# OAUTH_ISSUER=https://auth.jake.cafe/realms/homelab
# OAUTH_RESOURCE=https://music-dl.jake.cafe/mcp
# OAUTH_JWKS_URI=https://auth.jake.cafe/realms/homelab/protocol/openid-connect/certs
