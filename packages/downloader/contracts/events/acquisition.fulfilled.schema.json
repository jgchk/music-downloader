{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "acquisition.fulfilled"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "data": {
      "type": "object",
      "properties": {
        "acquisitionId": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "album",
                "track"
              ]
            },
            "artist": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "musicbrainzReleaseId": {
              "default": null,
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ]
            },
            "year": {
              "default": null,
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                {
                  "type": "null"
                }
              ]
            },
            "trackCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "type",
            "artist",
            "title",
            "musicbrainzReleaseId",
            "year",
            "trackCount"
          ]
        },
        "candidate": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "sizeBytes": {
              "type": "number"
            }
          },
          "required": [
            "username",
            "path",
            "sizeBytes"
          ]
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "name",
              "path"
            ]
          }
        }
      },
      "required": [
        "acquisitionId",
        "target",
        "candidate",
        "location",
        "files"
      ]
    }
  },
  "required": [
    "type",
    "timestamp",
    "data"
  ]
}
